# WikiKai environment template — copy to .env and customise.
# .env is gitignored. Never commit real tokens.

# Bearer token required for /mcp. Leave blank/unset to disable auth (local dev).
# Generate with: openssl rand -hex 32
WIKIKAI_TOKEN=

# Server bind + URL
# PORT=3939
# HOST=0.0.0.0
# PUBLIC_BASE_URL=http://localhost:3939   # surfaced in tool responses

# Data location
# DATA_DIR=./data
# DB_PATH=./data/index.db
# ITEMS_DIR=./data/items

# ─── Local-path image import (token-saver for same-machine files) ───
# When set, the MCP tool add_image accepts { path } and the server reads the
# file off its OWN disk — no base64 travels through the request (huge token
# saving when the image is already on this machine). Comma-separated ABSOLUTE
# dirs; only files resolving under one of them can be imported.
# DISABLED when unset. WARNING: /img is served without auth — keep roots NARROW
# (a dedicated images/imports dir), never $HOME or /, on any networked host.
# WIKIKAI_IMAGE_IMPORT_ROOTS=/srv/wikikai-imports,/data/screenshots

# ─── Web auth (Tier-1 login) ───
# WIKIKAI_WEB_AUTH=1               # turn the web login gate on
# WIKIKAI_ADMIN_EMAIL=you@example.com
# WIKIKAI_ADMIN_PASSWORD=...       # used ONCE to seed the admin user on first start;
#                                  # subsequent restarts ignore these if users exist
# WIKIKAI_ADMIN_NAME=Your Name
# WIKIKAI_MCP_DEFAULT_USER=1       # user-id stamped on activity-log rows from MCP
#                                  # (defaults to the bootstrap admin's id)
