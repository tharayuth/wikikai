# WikiKai environment template — copy to .env and customise.
# .env is gitignored. Never commit real tokens.

# Bearer token required for /mcp. Leave blank/unset to disable auth (local dev).
# Generate with: openssl rand -hex 32
WIKIKAI_TOKEN=

# Server bind + URL
# PORT=3939
# HOST=0.0.0.0
# PUBLIC_BASE_URL=http://localhost:3939   # surfaced in tool responses

# Data location
# DATA_DIR=./data
# DB_PATH=./data/index.db
# ITEMS_DIR=./data/items
